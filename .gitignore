# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.tox/
.nox/
.coverage
.coverage.*
.cache
htmlcov/
.pytest_cache/
coverage.xml
*.cover

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Linters / formatters
.ruff_cache/

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Editors and IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# OS junk
.DS_Store
Thumbs.db

# AXIOMM-specific: scratch outputs, large data, generated artefacts
scratch/
*.hspy
*.h5
*.hdf5
*.axiomm.json
!tests/**/*.h5
!tests/**/*.hspy
!tests/**/*.axiomm.json

# Logs
*.log

# Sphinx build outputs
docs/_build/
docs/autoapi/

# Local task / handoff notes that don't belong in version control
CLAUDE.md
checks.txt

# Design identity working folder: only the axiomm_wave assets and the
# Identity Kit are tracked; the .jsx sources, .thumbnail / state files,
# and the various Marks / Logo HTML drafts stay local.
identy/AXIOMM_Design/*
!identy/AXIOMM_Design/axiomm_wave_*.png
!identy/AXIOMM_Design/axiomm_wave_*.svg
!identy/AXIOMM_Design/AXIOMM Identity Kit.html
